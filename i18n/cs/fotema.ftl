people-page-status-no-people =
    .title = Nenalezeni žádní lidé
    .description =
        { -app-name } bude hledat tváře v nových fotkách při spuštění.
        Pojmenujte lidi ve svých fotkách, aby { -app-name } mohlo pro každou osobu vytvořit album.
people-page-status-off =
    .title = Zapnout zjišťování obličejů?
    .description = { -app-name } může automaticky zjišťovat obličeje a rozpoznávat lidi, ale toto je časově náročný proces. Chcete tuto funkci zapnout?
    .notice = { -app-name } si k rozpoznávání obličejů a lidí potřebuje stáhnout přibližně 45 megabajtů dat.
    .enable = Zapnout
onboard-select-pictures =
    .title = Vítejte v { -app-name }.
    .description =
        Vyberte složku ve které uchovávat vaši knihovnu obrázků.

        Pokud jste používali dřívější verzi { -app-name }, kde byly vaše obrázky automaticky objevovány, pak zde prosím vyberte stejnou složku, abyste se vyhnuli duplicitnímu zpracovávání obrázků.
    .button = Vybrat složku
